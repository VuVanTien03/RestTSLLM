  "components": {
    "schemas": {
      "AskMCPRequest": {
        "properties": {
          "conversation": {
            "items": {
              "$ref": "#/components/schemas/ConversationDTO"
            },
            "type": "array",
            "title": "Conversation"
          },
          "IdDonVi": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Iddonvi"
          },
          "max_iterations": {
            "type": "integer",
            "title": "Max Iterations",
            "default": 3
          },
          "chatId": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Chatid"
          }
        },
        "type": "object",
        "required": [
          "conversation"
        ],
        "title": "AskMCPRequest"
      },
      "AskMCPResponse": {
        "properties": {
          "response": {
            "type": "string",
            "title": "Response"
          }
        },
        "type": "object",
        "required": [
          "response"
        ],
        "title": "AskMCPResponse"
      },
      "Chat": {
        "properties": {
          "_id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "messages": {
            "items": {
              "$ref": "#/components/schemas/Message"
            },
            "type": "array",
            "title": "Messages"
          },
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "title": "Createdat"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time",
            "title": "Updatedat"
          }
        },
        "type": "object",
        "required": [
          "name",
          "userId",
          "createdAt",
          "updatedAt"
        ],
        "title": "Chat",
        "description": "Chat model",
        "example": {
          "createdAt": "2025-01-01T00:00:00",
          "messages": [
            {
              "content": "Hello",
              "role": "user",
              "timestamp": 1609459200000
            }
          ],
          "name": "New Chat",
          "updatedAt": "2025-01-01T00:00:00",
          "userId": "user123"
        }
      },
      "ChatAddMessage": {
        "properties": {
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "chatId": {
            "type": "string",
            "title": "Chatid"
          },
          "message": {
            "$ref": "#/components/schemas/Message"
          }
        },
        "type": "object",
        "required": [
          "userId",
          "chatId",
          "message"
        ],
        "title": "ChatAddMessage",
        "description": "Request model for adding a message to a chat",
        "example": {
          "chatId": "507f1f77bcf86cd799439011",
          "message": {
            "content": "Hello",
            "role": "user",
            "timestamp": 1609459200000
          },
          "userId": "user123"
        }
      },
      "ChatCreate": {
        "properties": {
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "name": {
            "type": "string",
            "title": "Name",
            "default": "New Chat"
          }
        },
        "type": "object",
        "required": [
          "userId"
        ],
        "title": "ChatCreate",
        "description": "Request model for creating a chat",
        "example": {
          "name": "My Chat",
          "userId": "user123"
        }
      },
      "ChatCreateResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "chatId": {
            "type": "string",
            "title": "Chatid"
          }
        },
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "title": "ChatCreateResponse",
        "description": "Response model for creating a chat"
      },
      "ChatDelete": {
        "properties": {
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "chatId": {
            "type": "string",
            "title": "Chatid"
          }
        },
        "type": "object",
        "required": [
          "userId",
          "chatId"
        ],
        "title": "ChatDelete",
        "description": "Request model for deleting a chat",
        "example": {
          "chatId": "507f1f77bcf86cd799439011",
          "userId": "user123"
        }
      },
      "ChatGet": {
        "properties": {
          "userId": {
            "type": "string",
            "title": "Userid"
          }
        },
        "type": "object",
        "required": [
          "userId"
        ],
        "title": "ChatGet",
        "description": "Request model for getting chats",
        "example": {
          "userId": "user123"
        }
      },
      "ChatGetById": {
        "properties": {
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "chatId": {
            "type": "string",
            "title": "Chatid"
          }
        },
        "type": "object",
        "required": [
          "userId",
          "chatId"
        ],
        "title": "ChatGetById",
        "description": "Request model for getting a specific chat by ID",
        "example": {
          "chatId": "507f1f77bcf86cd799439011",
          "userId": "user123"
        }
      },
      "ChatGetByIdResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "data": {
            "$ref": "#/components/schemas/Chat"
          }
        },
        "type": "object",
        "required": [
          "success"
        ],
        "title": "ChatGetByIdResponse",
        "description": "Response model for getting a chat by ID"
      },
      "ChatGetResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "data": {
            "items": {
              "$ref": "#/components/schemas/Chat"
            },
            "type": "array",
            "title": "Data"
          }
        },
        "type": "object",
        "required": [
          "success"
        ],
        "title": "ChatGetResponse",
        "description": "Response model for getting chats"
      },
      "ChatRename": {
        "properties": {
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "chatId": {
            "type": "string",
            "title": "Chatid"
          },
          "name": {
            "type": "string",
            "title": "Name"
          }
        },
        "type": "object",
        "required": [
          "userId",
          "chatId",
          "name"
        ],
        "title": "ChatRename",
        "description": "Request model for renaming a chat",
        "example": {
          "chatId": "507f1f77bcf86cd799439011",
          "name": "Updated Chat Name",
          "userId": "user123"
        }
      },
      "ChatResponse": {
        "properties": {
          "success": {
            "type": "boolean",
            "title": "Success"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "success",
          "message"
        ],
        "title": "ChatResponse",
        "description": "Response model for renaming a chat"
      },
      "ConversationDTO": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "title": "ConversationDTO"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Message": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "timestamp": {
            "type": "number",
            "title": "Timestamp"
          }
        },
        "type": "object",
        "required": [
          "role",
          "content",
          "timestamp"
        ],
        "title": "Message",
        "description": "Message model",
        "example": {
          "content": "Hello, how are you?",
          "role": "user",
          "timestamp": 1609459200000
        }
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
